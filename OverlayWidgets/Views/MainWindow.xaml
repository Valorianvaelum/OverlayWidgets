<Window x:Class="OverlayWidgets.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:OverlayWidgets.ViewModels"
        Title="OverlayWidgets"
        Width="1280"
        Height="720">
  <Window.Resources>
    <Style x:Key="OverlayWidgetChrome" TargetType="Border">
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Background" Value="#CC151A20" />
      <Setter Property="BorderBrush" Value="#66FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.35" />
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="EditPanelChrome" TargetType="Border">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Background" Value="#E51F2937" />
    </Style>
  </Window.Resources>

  <Grid Background="Transparent">
    <ItemsControl ItemsSource="{Binding Widgets}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <Canvas />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemContainerStyle>
        <Style TargetType="ContentPresenter">
          <Setter Property="Canvas.Left" Value="{Binding Left}" />
          <Setter Property="Canvas.Top" Value="{Binding Top}" />
          <Setter Property="Width" Value="{Binding Width}" />
          <Setter Property="Height" Value="{Binding Height}" />
        </Style>
      </ItemsControl.ItemContainerStyle>
      <ItemsControl.ItemTemplate>
        <DataTemplate DataType="{x:Type viewModels:WidgetHostViewModel}">
          <Border Style="{StaticResource OverlayWidgetChrome}"
                  MouseLeftButtonDown="Widget_MouseLeftButtonDown"
                  MouseMove="Widget_MouseMove"
                  MouseLeftButtonUp="Widget_MouseLeftButtonUp">
            <Grid>
              <ContentControl Content="{Binding Content}" />
              <Border HorizontalAlignment="Stretch"
                      VerticalAlignment="Top"
                      Height="24"
                      Margin="-8,-8,-8,0"
                      Background="#33000000"
                      Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding DisplayName}"
                           Margin="8,0"
                           VerticalAlignment="Center"
                           Foreground="#E5FFFFFF"
                           FontSize="11" />
              </Border>
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <Border Style="{StaticResource EditPanelChrome}"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Margin="16"
            Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
      <StackPanel>
        <StackPanel Orientation="Horizontal">
          <Ellipse Width="8"
                   Height="8"
                   Fill="#22C55E"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0" />
          <TextBlock Text="Modo edicion activo"
                     Foreground="White"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <Button Content="Bloquear"
                  Margin="12,0,0,0"
                  Padding="10,4"
                  Command="{Binding ToggleEditModeCommand}" />
        </StackPanel>
        <TextBlock Text="Arrastra widgets para ubicarlos. Ctrl+Shift+O vuelve a editar."
                   Foreground="#CBD5E1"
                   FontSize="11"
                   Margin="16,6,0,0" />
        <TextBlock Text="Atajo global no disponible; otra app puede estar usandolo."
                   Foreground="#FCA5A5"
                   FontSize="11"
                   Margin="16,4,0,0"
                   Visibility="Collapsed"
                   x:Name="HotkeyUnavailableText" />
      </StackPanel>
    </Border>

    <Border Style="{StaticResource EditPanelChrome}"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="16"
            Width="230"
            Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
      <StackPanel>
        <TextBlock Text="Widgets"
                   Foreground="White"
                   FontWeight="SemiBold" />
        <TextBlock Text="Activa o desactiva lo que queres ver."
                   Foreground="#CBD5E1"
                   FontSize="11"
                   Margin="0,4,0,8"
                   TextWrapping="Wrap" />
        <ItemsControl ItemsSource="{Binding WidgetOptions}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type viewModels:WidgetOptionViewModel}">
              <CheckBox Content="{Binding DisplayName}"
                        IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Foreground="White"
                        Margin="0,4,0,0" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>
  </Grid>
</Window>
