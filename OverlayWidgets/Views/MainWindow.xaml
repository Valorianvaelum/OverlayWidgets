<Window x:Class="OverlayWidgets.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:OverlayWidgets.ViewModels"
        Title="OverlayWidgets"
        Width="1280"
        Height="720">
  <Window.Resources>
    <SolidColorBrush x:Key="HudTextPrimary" Color="#FFF7FF" />
    <SolidColorBrush x:Key="HudTextSecondary" Color="#D6B8D8" />
    <SolidColorBrush x:Key="HudTextMuted" Color="#8E789A" />
    <SolidColorBrush x:Key="HudMagenta" Color="#FF4FD8" />
    <SolidColorBrush x:Key="HudViolet" Color="#B45CFF" />
    <SolidColorBrush x:Key="HudHotPink" Color="#FF79C6" />
    <SolidColorBrush x:Key="HudCyan" Color="#4DE7FF" />
    <SolidColorBrush x:Key="HudAmber" Color="#FFB84D" />
    <SolidColorBrush x:Key="HudGreen" Color="#B6FF5C" />
    <SolidColorBrush x:Key="HudPanelDark" Color="#F0070610" />
    <SolidColorBrush x:Key="HudPanelMid" Color="#E1120B1F" />
    <SolidColorBrush x:Key="HudBorderSoft" Color="#77FF4FD8" />

    <LinearGradientBrush x:Key="HudPanelGradient" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#F4070610" Offset="0" />
      <GradientStop Color="#E9180A28" Offset="0.46" />
      <GradientStop Color="#D7270A34" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HudWidgetGradient" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#EF080611" Offset="0" />
      <GradientStop Color="#DD160B24" Offset="0.48" />
      <GradientStop Color="#CC2B0B38" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="HudButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource HudTextPrimary}" />
      <Setter Property="Background" Value="#3DFF4FD8" />
      <Setter Property="BorderBrush" Value="#DDFF4FD8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="16,7" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="2">
              <Grid>
                <Rectangle Width="4"
                           HorizontalAlignment="Left"
                           Fill="{StaticResource HudCyan}" />
                <Rectangle Height="1"
                           VerticalAlignment="Top"
                           Fill="#88FFFFFF" />
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="10,0" />
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="#66FF4FD8" />
                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFFFFF" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Background" Value="#88B45CFF" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="HudCheckBox" TargetType="CheckBox">
      <Setter Property="Foreground" Value="{StaticResource HudTextPrimary}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <Border x:Name="Root"
                    Background="#33080611"
                    BorderBrush="#66FF4FD8"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="8,7"
                    Margin="0,5,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="42" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid Width="32" Height="16" HorizontalAlignment="Left" VerticalAlignment="Center">
                  <Border x:Name="Indicator"
                          Background="#22000000"
                          BorderBrush="#99D6B8D8"
                          BorderThickness="1"
                          CornerRadius="2" />
                  <Rectangle x:Name="Dot"
                             Width="10"
                             Height="10"
                             HorizontalAlignment="Left"
                             Margin="3,0,0,0"
                             Fill="#FFD6B8D8" />
                </Grid>
                <ContentPresenter Grid.Column="1"
                                  VerticalAlignment="Center"
                                  RecognizesAccessKey="True" />
                <TextBlock Grid.Column="2"
                           Text="LINK"
                           Foreground="{StaticResource HudTextMuted}"
                           FontSize="8"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFF4FD8" />
                <Setter TargetName="Root" Property="Background" Value="#44FF4FD8" />
                <Setter TargetName="Indicator" Property="BorderBrush" Value="#FFFF79C6" />
                <Setter TargetName="Indicator" Property="Background" Value="#33120B1F" />
                <Setter TargetName="Dot" Property="HorizontalAlignment" Value="Right" />
                <Setter TargetName="Dot" Property="Margin" Value="0,0,3,0" />
                <Setter TargetName="Dot" Property="Fill" Value="#FFB6FF5C" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFFFFF" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="OverlayWidgetChrome" TargetType="Border">
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="{StaticResource HudWidgetGradient}" />
      <Setter Property="BorderBrush" Value="#D9FF4FD8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="14" />
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect Color="#FF4FD8" BlurRadius="24" ShadowDepth="0" Opacity="0.36" />
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="EditPanelChrome" TargetType="Border">
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Background" Value="{StaticResource HudPanelGradient}" />
      <Setter Property="BorderBrush" Value="#CCFF4FD8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect Color="#FF4FD8" BlurRadius="22" ShadowDepth="0" Opacity="0.30" />
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ResizeThumbStyle" TargetType="Thumb">
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="24" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="VerticalAlignment" Value="Bottom" />
      <Setter Property="Cursor" Value="SizeNWSE" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Thumb">
            <Border x:Name="Root"
                    Background="#EE24072E"
                    BorderBrush="#FFFF4FD8"
                    BorderThickness="1"
                    CornerRadius="2">
              <Grid>
                <TextBlock Text="↘"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#FFF7FF"
                           FontSize="11"
                           FontWeight="Bold" />
                <Rectangle Height="2"
                           Width="12"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Margin="0,0,4,4"
                           Fill="{StaticResource HudCyan}" />
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="#FF40104E" />
                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFFFFF" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid Background="Transparent">
    <ItemsControl ItemsSource="{Binding Widgets}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <Canvas />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemContainerStyle>
        <Style TargetType="ContentPresenter">
          <Setter Property="Canvas.Left" Value="{Binding Left}" />
          <Setter Property="Canvas.Top" Value="{Binding Top}" />
          <Setter Property="Width" Value="{Binding Width}" />
          <Setter Property="Height" Value="{Binding Height}" />
        </Style>
      </ItemsControl.ItemContainerStyle>
      <ItemsControl.ItemTemplate>
        <DataTemplate DataType="{x:Type viewModels:WidgetHostViewModel}">
          <Border Style="{StaticResource OverlayWidgetChrome}"
                  MouseLeftButtonDown="Widget_MouseLeftButtonDown"
                  MouseMove="Widget_MouseMove"
                  MouseLeftButtonUp="Widget_MouseLeftButtonUp">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>

              <Grid Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="-6,-6,-6,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Rectangle Width="4"
                             Height="20"
                             Fill="{StaticResource HudMagenta}" />
                  <Rectangle Width="2"
                             Height="20"
                             Fill="{StaticResource HudCyan}"
                             Margin="3,0,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                  <TextBlock Text="UNIT FRAME"
                             Foreground="{StaticResource HudMagenta}"
                             FontSize="9"
                             FontWeight="Bold" />
                  <TextBlock Text=" // "
                             Foreground="#66FFFFFF"
                             FontSize="9"
                             FontWeight="Bold" />
                  <TextBlock Text="{Binding DisplayName}"
                             Foreground="{StaticResource HudTextPrimary}"
                             FontSize="11"
                             FontWeight="Bold" />
                </StackPanel>
                <TextBlock Grid.Column="2"
                           Text="SYNC / EDIT"
                           Foreground="{StaticResource HudGreen}"
                           FontSize="9"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
              </Grid>

              <Grid Grid.Row="1">
                <ContentControl Content="{Binding Content}" />
                <Rectangle Height="2"
                           VerticalAlignment="Top"
                           Fill="#55FF4FD8" />
                <Rectangle Width="2"
                           HorizontalAlignment="Right"
                           Fill="#444DE7FF" />
                <Rectangle Width="36"
                           Height="2"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Bottom"
                           Fill="#AAFFB84D" />
              </Grid>

              <Thumb Grid.RowSpan="2"
                     Style="{StaticResource ResizeThumbStyle}"
                     DragStarted="ResizeThumb_DragStarted"
                     DragDelta="ResizeThumb_DragDelta"
                     Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <Border Style="{StaticResource EditPanelChrome}"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Margin="18"
            MinWidth="470"
            Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Border Width="48"
                Height="48"
                Background="#3324072E"
                BorderBrush="{StaticResource HudMagenta}"
                BorderThickness="1"
                CornerRadius="2"
                Margin="0,0,12,0">
          <Grid>
            <Rectangle Width="28"
                       Height="28"
                       Stroke="{StaticResource HudMagenta}"
                       StrokeThickness="1"
                       Opacity="0.85" />
            <Ellipse Width="11"
                     Height="11"
                     Fill="{StaticResource HudGreen}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
            <Rectangle Width="2"
                       Height="38"
                       Fill="{StaticResource HudCyan}"
                       HorizontalAlignment="Right"
                       Margin="0,0,6,0" />
          </Grid>
        </Border>
        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="UNIT CONTROL"
                       Foreground="{StaticResource HudMagenta}"
                       FontWeight="Bold"
                       FontSize="11" />
            <TextBlock Text=" // EDIT INTERFACE ACTIVE"
                       Foreground="{StaticResource HudTextPrimary}"
                       FontWeight="Bold"
                       FontSize="11" />
          </StackPanel>
          <TextBlock Text="Drag para posicionar · esquina ↘ para redimensionar · Ctrl+Shift+O recupera sincronizacion"
                     Foreground="{StaticResource HudTextSecondary}"
                     FontSize="11"
                     Margin="0,5,0,0" />
          <TextBlock Text="Atajo global no disponible; otra app puede estar usandolo."
                     Foreground="#FF9BB0"
                     FontSize="11"
                     Margin="0,4,0,0"
                     Visibility="Collapsed"
                     x:Name="HotkeyUnavailableText" />
        </StackPanel>
        <Button Grid.Column="2"
                Style="{StaticResource HudButton}"
                Content="LOCK UNIT HUD"
                Margin="14,0,0,0"
                Command="{Binding ToggleEditModeCommand}" />
      </Grid>
    </Border>

    <Border Style="{StaticResource EditPanelChrome}"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="18"
            Width="270"
            Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
      <StackPanel>
        <Grid Margin="0,0,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel>
            <TextBlock Text="MODULE BAY"
                       Foreground="{StaticResource HudHotPink}"
                       FontSize="10"
                       FontWeight="Bold" />
            <TextBlock Text="ACTIVE LOADOUT"
                       Foreground="{StaticResource HudTextPrimary}"
                       FontSize="16"
                       FontWeight="Bold" />
          </StackPanel>
          <Border Grid.Column="1"
                  Width="42"
                  Height="24"
                  BorderBrush="{StaticResource HudGreen}"
                  BorderThickness="1"
                  CornerRadius="2"
                  Background="#22B6FF5C">
            <TextBlock Text="SYNC"
                       Foreground="{StaticResource HudGreen}"
                       FontSize="9"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
        </Grid>
        <TextBlock Text="Vincula modulos visuales al HUD activo."
                   Foreground="{StaticResource HudTextSecondary}"
                   FontSize="11"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap" />
        <ItemsControl ItemsSource="{Binding WidgetOptions}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type viewModels:WidgetOptionViewModel}">
              <CheckBox Content="{Binding DisplayName}"
                        Style="{StaticResource HudCheckBox}"
                        IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>
  </Grid>
</Window>
