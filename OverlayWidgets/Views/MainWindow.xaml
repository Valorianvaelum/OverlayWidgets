<Window x:Class="OverlayWidgets.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:OverlayWidgets.ViewModels"
        Title="OverlayWidgets"
        Width="1280"
        Height="720">
  <Window.Resources>
    <SolidColorBrush x:Key="HudInk" Color="#F1030610" />
    <SolidColorBrush x:Key="HudPanel" Color="#E9081018" />
    <SolidColorBrush x:Key="HudPanelSoft" Color="#CC101D24" />
    <SolidColorBrush x:Key="HudWhite" Color="#FFF7EFD8" />
    <SolidColorBrush x:Key="HudMuted" Color="#B7AFA892" />
    <SolidColorBrush x:Key="HudGreen" Color="#7CFF55" />
    <SolidColorBrush x:Key="HudAmber" Color="#FFB000" />
    <SolidColorBrush x:Key="HudOrange" Color="#FF6B00" />
    <SolidColorBrush x:Key="HudRed" Color="#FF2D2D" />
    <SolidColorBrush x:Key="HudCyan" Color="#38DDF2" />
    <SolidColorBrush x:Key="HudViolet" Color="#8B5CF6" />

    <LinearGradientBrush x:Key="HudPanelGradient" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#F3040710" Offset="0" />
      <GradientStop Color="#E90A1820" Offset="0.42" />
      <GradientStop Color="#D9160D12" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HudWidgetGradient" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#F2030610" Offset="0" />
      <GradientStop Color="#E20B151D" Offset="0.52" />
      <GradientStop Color="#D4120B13" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="HudButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource HudWhite}" />
      <Setter Property="Background" Value="#44281400" />
      <Setter Property="BorderBrush" Value="#DDFFB000" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="16,7" />
      <Setter Property="FontFamily" Value="Bahnschrift Condensed, Bahnschrift, Segoe UI" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="6" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="6" />
                </Grid.ColumnDefinitions>
                <Rectangle Fill="{StaticResource HudRed}" />
                <ContentPresenter Grid.Column="1"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="10,0" />
                <Rectangle Grid.Column="2" Fill="{StaticResource HudGreen}" />
                <Rectangle Grid.ColumnSpan="3"
                           Height="1"
                           VerticalAlignment="Top"
                           Fill="#AAFFF7EFD8" />
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="#66401800" />
                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFFFFF" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Background" Value="#AAFF6B00" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="HudCheckBox" TargetType="CheckBox">
      <Setter Property="Foreground" Value="{StaticResource HudWhite}" />
      <Setter Property="FontFamily" Value="Bahnschrift, Segoe UI" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <Border x:Name="Root"
                    Background="#33101517"
                    BorderBrush="#887CFF55"
                    BorderThickness="1"
                    CornerRadius="0"
                    Padding="8,7"
                    Margin="0,5,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="48" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid Width="38" Height="16" HorizontalAlignment="Left" VerticalAlignment="Center">
                  <Border x:Name="Indicator"
                          Background="#22000000"
                          BorderBrush="#99B7AFA892"
                          BorderThickness="1"
                          CornerRadius="0" />
                  <Rectangle x:Name="Dot"
                             Width="11"
                             Height="10"
                             HorizontalAlignment="Left"
                             Margin="3,0,0,0"
                             Fill="#FFB7AFA892" />
                </Grid>
                <ContentPresenter Grid.Column="1"
                                  VerticalAlignment="Center"
                                  RecognizesAccessKey="True" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                  <Rectangle Width="3" Height="12" Fill="{StaticResource HudAmber}" Margin="0,0,4,0" />
                  <TextBlock Text="CH"
                             Foreground="{StaticResource HudMuted}"
                             FontSize="9"
                             FontWeight="Bold" />
                </StackPanel>
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Root" Property="BorderBrush" Value="#FF7CFF55" />
                <Setter TargetName="Root" Property="Background" Value="#33224715" />
                <Setter TargetName="Indicator" Property="BorderBrush" Value="#FF7CFF55" />
                <Setter TargetName="Indicator" Property="Background" Value="#2211220A" />
                <Setter TargetName="Dot" Property="HorizontalAlignment" Value="Right" />
                <Setter TargetName="Dot" Property="Margin" Value="0,0,3,0" />
                <Setter TargetName="Dot" Property="Fill" Value="#FF7CFF55" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFB000" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="OverlayWidgetChrome" TargetType="Border">
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Background" Value="{StaticResource HudWidgetGradient}" />
      <Setter Property="BorderBrush" Value="#CC7CFF55" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="14" />
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect Color="#7CFF55" BlurRadius="12" ShadowDepth="0" Opacity="0.22" />
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="EditPanelChrome" TargetType="Border">
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Background" Value="{StaticResource HudPanelGradient}" />
      <Setter Property="BorderBrush" Value="#DDFFB000" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect Color="#FFB000" BlurRadius="14" ShadowDepth="0" Opacity="0.22" />
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ResizeThumbStyle" TargetType="Thumb">
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="24" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="VerticalAlignment" Value="Bottom" />
      <Setter Property="Cursor" Value="SizeNWSE" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Thumb">
            <Border x:Name="Root"
                    Background="#EE1D1000"
                    BorderBrush="#FFFFB000"
                    BorderThickness="1"
                    CornerRadius="0">
              <Grid>
                <TextBlock Text="↘"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource HudWhite}"
                           FontSize="11"
                           FontWeight="Bold" />
                <Rectangle Height="2"
                           Width="12"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Margin="0,0,4,4"
                           Fill="{StaticResource HudGreen}" />
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="#FF3A1D00" />
                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFFFFF" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid Background="Transparent">
    <ItemsControl ItemsSource="{Binding Widgets}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <Canvas />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemContainerStyle>
        <Style TargetType="ContentPresenter">
          <Setter Property="Canvas.Left" Value="{Binding Left}" />
          <Setter Property="Canvas.Top" Value="{Binding Top}" />
          <Setter Property="Width" Value="{Binding Width}" />
          <Setter Property="Height" Value="{Binding Height}" />
        </Style>
      </ItemsControl.ItemContainerStyle>
      <ItemsControl.ItemTemplate>
        <DataTemplate DataType="{x:Type viewModels:WidgetHostViewModel}">
          <Border Style="{StaticResource OverlayWidgetChrome}"
                  MouseLeftButtonDown="Widget_MouseLeftButtonDown"
                  MouseMove="Widget_MouseMove"
                  MouseLeftButtonUp="Widget_MouseLeftButtonUp">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>

              <Grid Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="-6,-6,-6,9">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Rectangle Width="5" Height="22" Fill="{StaticResource HudRed}" />
                  <Rectangle Width="3" Height="22" Fill="{StaticResource HudAmber}" Margin="3,0,0,0" />
                  <Rectangle Width="2" Height="22" Fill="{StaticResource HudGreen}" Margin="3,0,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                  <TextBlock Text="DISPLAY UNIT"
                             Foreground="{StaticResource HudAmber}"
                             FontFamily="Bahnschrift Condensed, Bahnschrift, Segoe UI"
                             FontSize="11"
                             FontWeight="Bold" />
                  <TextBlock Text=" // "
                             Foreground="#66FFF7EFD8"
                             FontSize="10"
                             FontWeight="Bold" />
                  <TextBlock Text="{Binding DisplayName}"
                             Foreground="{StaticResource HudWhite}"
                             FontFamily="Bahnschrift, Segoe UI"
                             FontSize="11"
                             FontWeight="Bold" />
                </StackPanel>
                <TextBlock Grid.Column="2"
                           Text="MANUAL TRIM"
                           Foreground="{StaticResource HudGreen}"
                           FontFamily="Bahnschrift Condensed, Bahnschrift, Segoe UI"
                           FontSize="10"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
              </Grid>

              <Grid Grid.Row="1">
                <ContentControl Content="{Binding Content}" />
                <Rectangle Height="2" VerticalAlignment="Top" Fill="#AA7CFF55" />
                <Rectangle Width="2" HorizontalAlignment="Left" Fill="#66FF2D2D" />
                <Rectangle Width="2" HorizontalAlignment="Right" Fill="#66FFB000" />
                <Rectangle Width="54" Height="2" HorizontalAlignment="Left" VerticalAlignment="Bottom" Fill="#DD38DDF2" />
                <Rectangle Width="36" Height="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="#DDFF6B00" />
              </Grid>

              <Thumb Grid.RowSpan="2"
                     Style="{StaticResource ResizeThumbStyle}"
                     DragStarted="ResizeThumb_DragStarted"
                     DragDelta="ResizeThumb_DragDelta"
                     Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <Border Style="{StaticResource EditPanelChrome}"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Margin="18"
            MinWidth="510"
            Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Border Width="54" Height="50" Background="#33101517" BorderBrush="{StaticResource HudAmber}" BorderThickness="1" Margin="0,0,12,0">
          <Grid>
            <Rectangle Width="34" Height="28" Stroke="{StaticResource HudGreen}" StrokeThickness="1" />
            <Rectangle Width="16" Height="16" Stroke="{StaticResource HudRed}" StrokeThickness="1" />
            <Rectangle Width="3" Height="40" Fill="{StaticResource HudAmber}" HorizontalAlignment="Right" Margin="0,0,7,0" />
            <TextBlock Text="OPS" Foreground="{StaticResource HudWhite}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4" />
          </Grid>
        </Border>
        <StackPanel Grid.Column="1" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="PILOT DISPLAY CONTROL"
                       Foreground="{StaticResource HudAmber}"
                       FontFamily="Bahnschrift Condensed, Bahnschrift, Segoe UI"
                       FontWeight="Bold"
                       FontSize="13" />
            <TextBlock Text=" // EDIT MODE"
                       Foreground="{StaticResource HudWhite}"
                       FontFamily="Bahnschrift Condensed, Bahnschrift, Segoe UI"
                       FontWeight="Bold"
                       FontSize="13" />
          </StackPanel>
          <TextBlock Text="Drag: panel position · Trim: lower-right handle · Ctrl+Shift+O: return to manual display control"
                     Foreground="{StaticResource HudMuted}"
                     FontFamily="Bahnschrift, Segoe UI"
                     FontSize="11"
                     Margin="0,5,0,0" />
          <TextBlock Text="Global hotkey unavailable; another process may own this control channel."
                     Foreground="#FFFF8080"
                     FontFamily="Bahnschrift, Segoe UI"
                     FontSize="11"
                     Margin="0,4,0,0"
                     Visibility="Collapsed"
                     x:Name="HotkeyUnavailableText" />
        </StackPanel>
        <Button Grid.Column="2"
                Style="{StaticResource HudButton}"
                Content="SECURE DISPLAY"
                Margin="14,0,0,0"
                Command="{Binding ToggleEditModeCommand}" />
      </Grid>
    </Border>

    <Border Style="{StaticResource EditPanelChrome}"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="18"
            Width="286"
            Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
      <StackPanel>
        <Grid Margin="0,0,0,9">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel>
            <TextBlock Text="SUB MONITOR BUS"
                       Foreground="{StaticResource HudGreen}"
                       FontFamily="Bahnschrift Condensed, Bahnschrift, Segoe UI"
                       FontSize="12"
                       FontWeight="Bold" />
            <TextBlock Text="DISPLAY CHANNELS"
                       Foreground="{StaticResource HudWhite}"
                       FontFamily="Bahnschrift Condensed, Bahnschrift, Segoe UI"
                       FontSize="18"
                       FontWeight="Bold" />
          </StackPanel>
          <Border Grid.Column="1" Width="46" Height="25" BorderBrush="{StaticResource HudRed}" BorderThickness="1" Background="#33200000">
            <TextBlock Text="I/O"
                       Foreground="{StaticResource HudRed}"
                       FontSize="10"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
        </Grid>
        <TextBlock Text="Route auxiliary displays into the active cockpit overlay."
                   Foreground="{StaticResource HudMuted}"
                   FontFamily="Bahnschrift, Segoe UI"
                   FontSize="11"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap" />
        <ItemsControl ItemsSource="{Binding WidgetOptions}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type viewModels:WidgetOptionViewModel}">
              <CheckBox Content="{Binding DisplayName}"
                        Style="{StaticResource HudCheckBox}"
                        IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>
  </Grid>
</Window>
