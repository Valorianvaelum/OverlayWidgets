<UserControl x:Class="OverlayWidgets.Views.Widgets.MediaWidgetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Rectangle Width="4"
                 Height="20"
                 Fill="#F472B6"
                 RadiusX="2"
                 RadiusY="2" />
      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  Margin="8,0,0,0"
                  VerticalAlignment="Center">
        <TextBlock Text="MEDIA"
                   Foreground="#F472B6"
                   FontSize="10"
                   FontWeight="Bold" />
        <TextBlock Text=" // SESSION"
                   Foreground="#88F8FBFF"
                   FontSize="10"
                   FontWeight="Bold" />
      </StackPanel>
      <Border Grid.Column="2"
              BorderBrush="#6622D3EE"
              BorderThickness="1"
              CornerRadius="5"
              Background="#2212E9F3"
              Padding="7,2">
        <TextBlock Text="{Binding Status}"
                   Foreground="#22D3EE"
                   FontSize="10"
                   FontWeight="Bold" />
      </Border>
    </Grid>

    <StackPanel Grid.Row="1"
                VerticalAlignment="Center">
      <TextBlock Text="{Binding Title}"
                 Foreground="#F8FBFF"
                 FontSize="20"
                 FontWeight="Bold"
                 TextTrimming="CharacterEllipsis" />
      <TextBlock Text="{Binding Subtitle}"
                 Foreground="#A7B8CA"
                 FontSize="13"
                 FontWeight="SemiBold"
                 Margin="0,5,0,0"
                 TextTrimming="CharacterEllipsis" />
    </StackPanel>

    <Grid Grid.Row="2"
          Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="0.7*" />
      </Grid.ColumnDefinitions>
      <Rectangle Height="3"
                 Fill="#22D3EE"
                 RadiusX="1"
                 RadiusY="1" />
      <Rectangle Grid.Column="1"
                 Height="3"
                 Margin="6,0,0,0"
                 Fill="#F472B6"
                 RadiusX="1"
                 RadiusY="1" />
      <Rectangle Grid.Column="2"
                 Height="3"
                 Margin="6,0,0,0"
                 Fill="#F59E0B"
                 RadiusX="1"
                 RadiusY="1" />
    </Grid>
  </Grid>
</UserControl>
