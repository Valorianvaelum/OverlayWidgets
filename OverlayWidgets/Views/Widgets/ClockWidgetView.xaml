<UserControl x:Class="OverlayWidgets.Views.Widgets.ClockWidgetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Rectangle Width="4"
                 Height="20"
                 Fill="#22D3EE"
                 RadiusX="2"
                 RadiusY="2" />
      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  Margin="8,0,0,0"
                  VerticalAlignment="Center">
        <TextBlock Text="CHRONO"
                   Foreground="#22D3EE"
                   FontSize="10"
                   FontWeight="Bold" />
        <TextBlock Text=" // LOCAL TIME"
                   Foreground="#88F8FBFF"
                   FontSize="10"
                   FontWeight="Bold" />
      </StackPanel>
      <TextBlock Grid.Column="2"
                 Text="LIVE"
                 Foreground="#7CFF6B"
                 FontSize="10"
                 FontWeight="Bold"
                 VerticalAlignment="Center" />
    </Grid>

    <Grid Grid.Row="1"
          VerticalAlignment="Center">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBlock Text="{Binding Time}"
                 Foreground="#F8FBFF"
                 FontFamily="Cascadia Mono, Consolas, Segoe UI"
                 FontSize="38"
                 FontWeight="Bold"
                 TextOptions.TextFormattingMode="Display" />
      <StackPanel Grid.Column="1"
                  Margin="12,0,0,0"
                  VerticalAlignment="Center">
        <Rectangle Width="34"
                   Height="2"
                   Fill="#F472B6"
                   HorizontalAlignment="Right" />
        <Rectangle Width="22"
                   Height="2"
                   Fill="#22D3EE"
                   HorizontalAlignment="Right"
                   Margin="0,5,0,0" />
        <Rectangle Width="12"
                   Height="2"
                   Fill="#F59E0B"
                   HorizontalAlignment="Right"
                   Margin="0,5,0,0" />
      </StackPanel>
    </Grid>

    <Border Grid.Row="2"
            Margin="0,8,0,0"
            BorderBrush="#4422D3EE"
            BorderThickness="1,0,0,0"
            Padding="8,3,0,0">
      <TextBlock Text="{Binding Date}"
                 Foreground="#A7B8CA"
                 FontSize="12"
                 FontWeight="SemiBold" />
    </Border>
  </Grid>
</UserControl>
