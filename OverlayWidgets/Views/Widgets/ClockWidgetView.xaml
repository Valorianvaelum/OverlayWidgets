<UserControl x:Class="OverlayWidgets.Views.Widgets.ClockWidgetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal">
        <Rectangle Width="4"
                   Height="22"
                   Fill="#FF4FD8" />
        <Rectangle Width="2"
                   Height="22"
                   Fill="#4DE7FF"
                   Margin="3,0,0,0" />
      </StackPanel>
      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  Margin="9,0,0,0"
                  VerticalAlignment="Center">
        <TextBlock Text="TIME CORE"
                   Foreground="#FF4FD8"
                   FontSize="10"
                   FontWeight="Bold" />
        <TextBlock Text=" // SYNCHRO CLOCK"
                   Foreground="#9AD6B8D8"
                   FontSize="10"
                   FontWeight="Bold" />
      </StackPanel>
      <TextBlock Grid.Column="2"
                 Text="SYNC 100"
                 Foreground="#B6FF5C"
                 FontSize="10"
                 FontWeight="Bold"
                 VerticalAlignment="Center" />
    </Grid>

    <Grid Grid.Row="1"
          VerticalAlignment="Center">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="{Binding Time}"
                   Foreground="#FFF7FF"
                   FontFamily="Cascadia Mono, Consolas, Segoe UI"
                   FontSize="39"
                   FontWeight="Bold"
                   TextOptions.TextFormattingMode="Display" />
        <Rectangle Height="2"
                   Fill="#AAFF4FD8"
                   Margin="1,2,20,0" />
      </StackPanel>
      <StackPanel Grid.Column="1"
                  Margin="12,0,0,0"
                  VerticalAlignment="Center">
        <Rectangle Width="36"
                   Height="3"
                   Fill="#FF4FD8"
                   HorizontalAlignment="Right" />
        <Rectangle Width="27"
                   Height="3"
                   Fill="#B45CFF"
                   HorizontalAlignment="Right"
                   Margin="0,5,0,0" />
        <Rectangle Width="16"
                   Height="3"
                   Fill="#4DE7FF"
                   HorizontalAlignment="Right"
                   Margin="0,5,0,0" />
        <Rectangle Width="8"
                   Height="3"
                   Fill="#FFB84D"
                   HorizontalAlignment="Right"
                   Margin="0,5,0,0" />
      </StackPanel>
    </Grid>

    <Grid Grid.Row="2"
          Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Rectangle Width="3"
                 Fill="#B45CFF" />
      <StackPanel Grid.Column="1"
                  Margin="8,2,0,0">
        <TextBlock Text="CALENDAR BUFFER"
                   Foreground="#8E789A"
                   FontSize="8"
                   FontWeight="Bold" />
        <TextBlock Text="{Binding Date}"
                   Foreground="#D6B8D8"
                   FontSize="12"
                   FontWeight="SemiBold" />
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
